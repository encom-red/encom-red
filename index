    <title>ENCOM - ISP Inalámbrico</title>
    <style>
        body, html { margin: 0; padding: 0; font-family: 'Segoe UI', sans-serif; background-color: #000; color: #fff; scroll-behavior: smooth; }
        .hero { 
            background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('edited-image.png'); 
            background-size: cover; background-position: center; height: 100vh; 
            display: flex; flex-direction: column; justify-content: center; align-items: center; 
        }
        .enter-button { 
            background: transparent; border: 2px solid #00d4ff; color: #00d4ff; padding: 15px 40px; 
            font-size: 1.2rem; text-transform: uppercase; cursor: pointer; letter-spacing: 3px; 
            box-shadow: 0 0 15px rgba(0, 212, 255, 0.5); transition: 0.3s; margin-top: 250px;
        }
        .enter-button:hover { background: #00d4ff; color: #000; box-shadow: 0 0 30px #00d4ff; }
        .plans-container { padding: 60px 20px; display: flex; justify-content: center; gap: 30px; flex-wrap: wrap; background: #00050a; }
        .plan-card { 
            background: rgba(0, 20, 40, 0.8); border: 1px solid #00d4ff; padding: 30px; 
            width: 280px; border-radius: 10px; text-align: center; transition: 0.3s; 
        }
        .plan-card:hover { transform: translateY(-10px); box-shadow: 0 0 25px rgba(0, 212, 255, 0.4); }
        .plan-card h3 { color: #00d4ff; text-transform: uppercase; }
        .plan-card ul { list-style: none; padding: 0; text-align: left; }
        .plan-card li { margin: 10px 0; font-size: 0.9rem; }
        .plan-card li::before { content: "▹"; color: #00d4ff; margin-right: 10px; }
        h2.section-title { text-align: center; padding: 40px 0; background: #00050a; color: #00d4ff; margin: 0; letter-spacing: 5px; }
    </style>
</head>
<body>
